{
  "name": "@erag/lang-sync-inertia",
  "version": "2.0.1",
  "description": "Unified Vue, React, and Svelte language sync helpers for Laravel Inertia",
  "homepage": "https://github.com/eramitgupta/lang-sync-inertia",
  "repository": {
    "type": "git",
    "url": "https://github.com/eramitgupta/lang-sync-inertia.git"
  },
  "bugs": {
    "url": "https://github.com/eramitgupta/lang-sync-inertia/issues"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue/index.js",
      "types": "./dist/vue/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    },
    "./svelte": {
      "import": "./dist/svelte/index.js",
      "types": "./dist/svelte/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build --config vite.config.ts && tsc -p tsconfig.json --emitDeclarationOnly",
    "prepare": "npm run build",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,md}\" \"*.{json,ts}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,json,md}\" \"*.{json,ts}\"",
    "lint": "eslint src",
    "lint:check": "npm run format:check && npm run lint",
    "type-check": "tsc --noEmit",
    "release": "release-it",
    "upgrade": "npx npm-check-updates -u"
  },
  "peerDependencies": {
    "@inertiajs/core": "^2.0.0 || ^3.0.0",
    "@inertiajs/react": "^2.0.0 || ^3.0.0",
    "@inertiajs/svelte": "^2.0.0 || ^3.0.0",
    "@inertiajs/vue3": "^2.0.0 || ^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "svelte": "^4.0.0 || ^5.0.0",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "release-it": "^20.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.0"
  },
  "release-it": {
    "git": {
      "requireCleanWorkingDir": true
    },
    "github": {
      "release": true,
      "host": "github.com",
      "repo": "eramitgupta/lang-sync-inertia"
    }
  }
}
